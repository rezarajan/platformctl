# Zero-Trust Lakehouse — secret values (copy to .env, fill, and source it).
#
#   cp .env.example .env && $EDITOR .env
#   set -a; . ./.env; set +a
#
# backend: env resolves DATASCAPE_SECRET_<NAME>_<KEY> — uppercased,
# '-' -> '_'. Every key below is required by 00-secrets.yaml.
# Use strong, unique values; these placeholders are NOT safe defaults.

# The openziti mesh admin (mesh-admin SecretReference).
export DATASCAPE_SECRET_MESH_ADMIN_USERNAME=admin
export DATASCAPE_SECRET_MESH_ADMIN_PASSWORD=change-me-mesh-admin

# The mediated Connection's DB credential (orders-db-replication).
# setup-external-db.sh stands up the dark Postgres with THIS user as its
# superuser, so the value here and the database must agree.
export DATASCAPE_SECRET_ORDERS_DB_REPLICATION_USERNAME=orders_repl
export DATASCAPE_SECRET_ORDERS_DB_REPLICATION_PASSWORD=change-me-orders-repl

# The orders DB admin (orders-db-admin) — reserved for direct admin use;
# the mediated CDC path uses orders-db-replication above.
export DATASCAPE_SECRET_ORDERS_DB_ADMIN_USERNAME=orders_admin
export DATASCAPE_SECRET_ORDERS_DB_ADMIN_PASSWORD=change-me-orders-admin

# The MySQL events source root (events-db-root).
export DATASCAPE_SECRET_EVENTS_DB_ROOT_USERNAME=root
export DATASCAPE_SECRET_EVENTS_DB_ROOT_PASSWORD=change-me-events-root

# The MinIO object-store root (lake-minio-root) — also the S3 credential a
# Dagster S3 IOManager uses (see README#connect-an-orchestrator).
export DATASCAPE_SECRET_LAKE_MINIO_ROOT_USERNAME=lakeadmin
export DATASCAPE_SECRET_LAKE_MINIO_ROOT_PASSWORD=change-me-minio-root
