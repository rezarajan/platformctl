        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cascadura/git/platformctl/scripts/hooks/fmt-and-lint.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cascadura/git/platformctl/scripts/hooks/guard-planning-docs.sh"
          }
        ]
      }
    ]
  }
}
