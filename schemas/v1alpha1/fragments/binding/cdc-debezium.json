{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datascape.io/schemas/fragments/binding/cdc-debezium.json",
  "title": "Binding(mode: cdc, providerRef type: debezium).spec.options",
  "description": "Shape-only fragment (docs/planning/08 E5), migrated from debezium.ValidateBindingOptions. Whether options.format's avro/protobuf actually has a schema registry to talk to remains a compatibility.Check graph concern.",
  "type": "object",
  "properties": {
    "tables": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "snapshotMode": {
      "type": "string",
      "enum": ["always", "initial", "initial_only", "no_data", "never", "when_needed", "schema_only", "schema_only_recovery"]
    },
    "databaseHostname": { "type": "string", "minLength": 1 },
    "databasePort": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "format": { "type": "string", "enum": ["json", "avro", "protobuf"] },
    "converter": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
