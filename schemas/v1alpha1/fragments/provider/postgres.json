{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datascape.io/schemas/fragments/provider/postgres.json",
  "title": "Provider(type: postgres).spec.configuration",
  "description": "Shape-only fragment (docs/planning/08 E5): the superuserSecretRef-or-nonempty-secretRefs fallback and *SecretRef spec.secretRefs-membership checks remain SpecValidator cross-field rules.",
  "type": "object",
  "properties": {
    "image": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "storage": {
      "type": "object",
      "properties": {
        "size": { "type": "string", "minLength": 1 },
        "class": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "superuserSecretRef": { "type": "string", "minLength": 1 },
    "replicationSecretRef": { "type": "string", "minLength": 1 },
    "metrics": { "type": "string", "enum": ["enabled", "disabled"] }
  },
  "additionalProperties": false
}
