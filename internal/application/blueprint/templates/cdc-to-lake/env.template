# platformctl cdc-to-lake blueprint — secrets for the `env` SecretStore
# backend (internal/adapters/secrets/env): each SecretReference key K of
# reference R resolves from DATASCAPE_SECRET_<R>_<K>, uppercased, with
# dashes mapped to underscores.
#
# Fill in real values, then either:
#   platformctl apply --env-file .env
# or export them into your shell first (`set -a; source .env; set +a`).
#
# Any key left unset here is reported by name at `apply` time (secret
# Preflight runs before any infrastructure is touched) rather than failing
# opaquely mid-apply.

DATASCAPE_SECRET_DB_ADMIN_CREDS_USERNAME=admin
DATASCAPE_SECRET_DB_ADMIN_CREDS_PASSWORD=change-me

DATASCAPE_SECRET_DB_REPLICATION_CREDS_USERNAME=replicator
DATASCAPE_SECRET_DB_REPLICATION_CREDS_PASSWORD=change-me

DATASCAPE_SECRET_LAKE_ROOT_CREDS_USERNAME=minioadmin
DATASCAPE_SECRET_LAKE_ROOT_CREDS_PASSWORD=change-me
